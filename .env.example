# Copy to .env and fill in after the Postgres instance is deployed. NEVER commit .env.
POSTGRES_PASSWORD=
PGUSER=postgres
PGDATABASE=postgres
PGHOST=

# Full DSN used by the API, seeder, and migrate tool.
# sslmode=require because Unikraft Cloud exposes Postgres over TLS.
DATABASE_URL=postgres://postgres:<password>@<fqdn>:5432/postgres?sslmode=require

PORT=8080
